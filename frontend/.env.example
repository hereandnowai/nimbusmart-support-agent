# =============================================================
#  PORT CONFIG — the ONE place to change ports for this app
#  (restart `npm run dev` after editing; Vite reads this at startup)
# =============================================================

# Port the frontend runs on (http://localhost:<VITE_PORT>).
# If this port is busy, the dev server STOPS with an explicit
# error instead of silently switching to another port.
VITE_PORT=5173

# Where the backend is running. Must match the --port you give uvicorn:
#   uv run uvicorn app.main:app --reload --port 8000
VITE_API_BASE_URL=http://localhost:8000
